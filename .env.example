# Local: a Homebrew/local Postgres. Vercel: injected by the Neon integration.
DATABASE_URL="postgresql://localhost:5432/foodbank"

# Wall-clock timezone of the food bank. "Wednesday 5pm" is local time, and Vercel runs UTC,
# so this must be explicit or DST will shift the slots by an hour twice a year.
FOOD_BANK_TZ="America/New_York"

SLOT_CAPACITY="30"
